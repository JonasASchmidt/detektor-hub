# Required for React Native / Expo — these packages rely on being resolvable
# from the root node_modules (not pnpm's default isolated layout).
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=*react*
public-hoist-pattern[]=@react-native-community/*
public-hoist-pattern[]=@expo/*
public-hoist-pattern[]=expo-*
public-hoist-pattern[]=babel-preset-expo
