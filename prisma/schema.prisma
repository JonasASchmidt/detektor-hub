generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("POSTGRES_PRISMA_URL")
  directUrl  = env("POSTGRES_URL_NON_POOLING")
  extensions = [postgis()]
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  password      String?
  emailVerified DateTime?
  image         String?
  role          String    @default("USER")
  accounts      Account[]
  comments      Comment[]
  findings      Finding[]
  fieldSessions FieldSession[]
  zones         Zone[]
  images        Image[]
  sessions      Session[]
  notificationsReceived Notification[] @relation("NotificationRecipient")
  notificationsSent     Notification[] @relation("NotificationActor")
  activityLogs  ActivityLog[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String  @unique
  access_token      String?
  expires_at        Int?
  refresh_token     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TagCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  tags      Tag[]
}

model Tag {
  id         String      @id @default(uuid())
  name       String      @unique
  categoryId String
  color      String
  icon       String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @default(now()) @updatedAt
  category   TagCategory @relation(fields: [categoryId], references: [id])
  findings   Finding[]   @relation("FindingTags")
  images     Image[]     @relation("ImageTags")
}

model Finding {
  id                String        @id @default(uuid())
  status            FindingStatus @default(DRAFT)
  reported          Boolean       @default(false)
  locationPublic    Boolean       @default(false)
  name              String?
  latitude          Float
  longitude         Float
  depth             Float?
  weight            Float?
  diameter          Float?
  description       String?
  description_front String?
  description_back  String?
  dating            String?
  dating_from       Int?
  dating_to         Int?
  references        String?
  foundAt           DateTime      @default(now())
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @default(now()) @updatedAt
  conductivity      Int?
  detectorId        String?
  thumbnailId       String?
  adminCountry      String?
  adminFederalState String?
  adminCounty       String?
  adminMunicipality String?
  userId            String
  fieldSessionId    String?
  comments          Comment[]
  detector          Detector?     @relation(fields: [detectorId], references: [id])
  user              User          @relation(fields: [userId], references: [id])
  fieldSession      FieldSession? @relation(fields: [fieldSessionId], references: [id])
  images            Image[]
  tags              Tag[]         @relation("FindingTags")
  Finding_A         Finding[]     @relation("RelatedFindings")
  Finding_B         Finding[]     @relation("RelatedFindings")
}

model Image {
  id               String   @id @default(uuid())
  findingId        String?
  commentId        String?
  userId           String
  url              String?
  publicId         String
  title            String?
  description      String?
  originalFilename String?
  fileSize         Int?
  width            Int?
  height           Int?
  folder           String   @default("All")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt
  finding          Finding? @relation(fields: [findingId], references: [id])
  comment          Comment? @relation(fields: [commentId], references: [id])
  user             User     @relation(fields: [userId], references: [id])
  tags             Tag[]    @relation("ImageTags")
}

model Detector {
  id            String         @id @default(uuid())
  name          String
  company       String
  url           String
  findings      Finding[]
  fieldSessions FieldSession[]
}

model Zone {
  id          String    @id @default(uuid())
  name        String
  description String?
  userId      String
  geometry    Unsupported("geometry(Polygon,4326)")?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  user        User      @relation(fields: [userId], references: [id])
  sessions    FieldSession[]
}

model FieldSession {
  id           String    @id @default(uuid())
  name         String
  description  String?
  namingScheme String?
  dateFrom     DateTime
  dateTo       DateTime?
  zoneId       String?
  detectorId   String?
  userId       String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt
  route        Unsupported("geometry(LineString,4326)")?
  zone         Zone?     @relation(fields: [zoneId], references: [id])
  detector     Detector? @relation(fields: [detectorId], references: [id])
  user         User      @relation(fields: [userId], references: [id])
  findings     Finding[]
}

model Comment {
  id        String    @id @default(uuid())
  userId    String
  findingId String
  parentId  String?
  text      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  
  finding   Finding   @relation(fields: [findingId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  children  Comment[] @relation("CommentReplies")
  attachments Image[]
}

model Notification {
  id          String           @id @default(uuid())
  type        NotificationType
  recipientId String
  actorId     String?
  findingId   String?
  commentId   String?
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())
  
  recipient   User             @relation("NotificationRecipient", fields: [recipientId], references: [id])
  actor       User?            @relation("NotificationActor", fields: [actorId], references: [id])
}

// Administrative unit tables are managed by scripts/create_administrative_units_table.py
// and must not be modified or dropped by Prisma — hence @@ignore.
model AdministrativeUnitsCountry {
  id_country BigInt
  name       String
  geometry   Unsupported("geometry")

  @@ignore
  @@map("administrative_units_country")
}

model AdministrativeUnitsFederalStates {
  id_country       BigInt
  id_federal_state BigInt
  name             String
  geometry         Unsupported("geometry")

  @@ignore
  @@map("administrative_units_federal_states")
}

model AdministrativeUnitsCounties {
  id_federal_state BigInt
  id_county        BigInt
  name             String
  geometry         Unsupported("geometry")

  @@ignore
  @@map("administrative_units_counties")
}

model AdministrativeUnitsMunicipalities {
  id_county       BigInt
  id_municipality BigInt
  name            String
  geometry        Unsupported("geometry")

  @@ignore
  @@map("administrative_units_municipalities")
}

// Run: npx prisma migrate dev --name add_activity_log
model ActivityLog {
  id            String   @id @default(uuid())
  userId        String
  action        String
  entityType    String
  entityId      String
  entityOwnerId String?
  changes       Json?
  metadata      Json?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])
}

enum NotificationType {
  MENTION
  REPLY
  FINDING_COMMENT
}

enum FindingStatus {
  DRAFT
  COMPLETED
}
