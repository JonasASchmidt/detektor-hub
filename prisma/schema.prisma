generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("POSTGRES_PRISMA_URL")
  directUrl  = env("POSTGRES_URL_NON_POOLING")
  extensions = [postgis()]
}

model User {
  id                    String             @id @default(uuid())
  name                  String?
  email                 String             @unique
  password              String?
  emailVerified         DateTime?
  image                 String?
  // Static role: "USER" | "OFFICIAL" | "ADMIN"
  // OFFICIAL means the user has at least one OfficialRole assignment; capabilities come from UserOfficialRole
  role                  String             @default("USER")
  accounts              Account[]
  comments              Comment[]
  findings              Finding[]
  fieldSessions         FieldSession[]
  zones                 Zone[]
  images                Image[]
  sessions              Session[]
  votes                 Vote[]
  notificationsReceived Notification[]     @relation("NotificationRecipient")
  notificationsSent     Notification[]     @relation("NotificationActor")
  activityLogs          ActivityLog[]
  collections           Collection[]
  profile               UserProfile?
  officialRoles         UserOfficialRole[] @relation("UserRoles")
  rolesAssigned         UserOfficialRole[] @relation("RoleAssigner")
  rolesCreated          OfficialRole[]     @relation("RoleCreator")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String  @unique
  access_token      String?
  expires_at        Int?
  refresh_token     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TagCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  tags      Tag[]
}

model Tag {
  id         String      @id @default(uuid())
  name       String      @unique
  categoryId String
  color      String
  icon       String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @default(now()) @updatedAt
  category   TagCategory @relation(fields: [categoryId], references: [id])
  findings   Finding[]   @relation("FindingTags")
  images     Image[]     @relation("ImageTags")
}

model Finding {
  id                String        @id @default(uuid())
  status            FindingStatus @default(DRAFT)
  reported          Boolean       @default(false)
  locationPublic    Boolean       @default(false)
  name              String?
  latitude          Float
  longitude         Float
  depth             Float?
  weight            Float?
  diameter          Float?
  description      String?
  descriptionFront String?
  descriptionBack  String?
  dating           String?
  datingFrom       Int?
  datingTo         Int?
  references        String?
  foundAt           DateTime      @default(now())
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @default(now()) @updatedAt
  conductivity      Int?
  detectorId        String?
  thumbnailId       String?
  adminCountry      String?
  adminFederalState String?
  adminCounty       String?
  adminMunicipality String?
  userId            String
  fieldSessionId    String?
  comments          Comment[]
  detector          Detector?     @relation(fields: [detectorId], references: [id])
  user              User          @relation(fields: [userId], references: [id])
  fieldSession      FieldSession? @relation(fields: [fieldSessionId], references: [id])
  images            Image[]
  tags              Tag[]         @relation("FindingTags")
  relatedTo         Finding[]     @relation("RelatedFindings")
  relatedFrom       Finding[]     @relation("RelatedFindings")
  collections       Collection[]  @relation("CollectionFindings")
}

model Collection {
  id          String    @id @default(uuid())
  name        String
  description String?
  userId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  user        User      @relation(fields: [userId], references: [id])
  findings    Finding[] @relation("CollectionFindings")
}

model Image {
  id               String   @id @default(uuid())
  findingId        String?
  commentId        String?
  userId           String
  url              String?
  publicId         String
  title            String?
  description      String?
  originalFilename String?
  fileSize         Int?
  width            Int?
  height           Int?
  folder           String   @default("All")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt
  finding          Finding? @relation(fields: [findingId], references: [id])
  comment          Comment? @relation(fields: [commentId], references: [id])
  user             User     @relation(fields: [userId], references: [id])
  tags             Tag[]    @relation("ImageTags")
}

model Detector {
  id            String         @id @default(uuid())
  name          String
  company       String
  url           String
  findings      Finding[]
  fieldSessions FieldSession[]
}

model Zone {
  id          String                                 @id @default(uuid())
  name        String
  description String?
  userId      String
  geometry    Unsupported("geometry(Polygon,4326)")?
  createdAt   DateTime                               @default(now())
  updatedAt   DateTime                               @default(now()) @updatedAt
  user        User                                   @relation(fields: [userId], references: [id])
  sessions    FieldSession[]
  roleScopes  OfficialRoleScope[]
}

model FieldSession {
  id           String                                    @id @default(uuid())
  name         String
  description  String?
  namingScheme String?
  dateFrom     DateTime
  dateTo       DateTime?
  zoneId       String?
  detectorId   String?
  userId       String
  createdAt    DateTime                                  @default(now())
  updatedAt    DateTime                                  @default(now()) @updatedAt
  route        Unsupported("geometry(LineString,4326)")?
  zone         Zone?                                     @relation(fields: [zoneId], references: [id])
  detector     Detector?                                 @relation(fields: [detectorId], references: [id])
  user         User                                      @relation(fields: [userId], references: [id])
  findings     Finding[]
}

model Comment {
  id        String   @id @default(uuid())
  userId    String
  findingId String
  parentId  String?
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  finding     Finding   @relation(fields: [findingId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
  parent      Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  children    Comment[] @relation("CommentReplies")
  attachments Image[]
}

model Notification {
  id          String           @id @default(uuid())
  type        NotificationType
  recipientId String
  actorId     String?
  findingId   String?
  commentId   String?
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())

  recipient User  @relation("NotificationRecipient", fields: [recipientId], references: [id])
  actor     User? @relation("NotificationActor", fields: [actorId], references: [id])
}

// Administrative unit tables are managed by scripts/create_administrative_units_table.py
// and must not be modified or dropped by Prisma — hence @@ignore.
model AdministrativeUnitsCountry {
  id_country BigInt
  name       String
  geometry   Unsupported("geometry")

  @@map("administrative_units_country")
  @@ignore
}

model AdministrativeUnitsFederalStates {
  id_country       BigInt
  id_federal_state BigInt
  name             String
  geometry         Unsupported("geometry")

  @@map("administrative_units_federal_states")
  @@ignore
}

model AdministrativeUnitsCounties {
  id_federal_state BigInt
  id_county        BigInt
  name             String
  geometry         Unsupported("geometry")

  @@map("administrative_units_counties")
  @@ignore
}

model AdministrativeUnitsMunicipalities {
  id_county       BigInt
  id_municipality BigInt
  name            String
  geometry        Unsupported("geometry")

  @@map("administrative_units_municipalities")
  @@ignore
}

model ActivityLog {
  id            String   @id @default(uuid())
  userId        String
  action        String
  entityType    String
  entityId      String
  entityOwnerId String?
  changes       Json?
  metadata      Json?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])
}

// Generic polymorphic vote — targetType: "FINDING" | "COMMENT" | ...
model Vote {
  id         String   @id @default(uuid())
  userId     String
  targetType String // e.g. "FINDING"
  targetId   String // ID of the voted entity
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
}

// ─── Official Role System ────────────────────────────────────────────────────

// Scope types an OfficialRole can be bound to
enum AdminUnitType {
  FEDERAL_STATE
  COUNTY
  MUNICIPALITY
  ZONE
}

// A named role created by an official within their admin unit.
// Capabilities are a string array validated against the CAPABILITIES constant in lib/capabilities.ts.
// Priority determines which badge is shown when a user holds multiple roles (higher = preferred).
model OfficialRole {
  id              String   @id @default(uuid())
  name            String
  description     String?
  capabilities    String[]
  badgeLabel      String?  // Short label shown next to username, e.g. "BY-Mod"
  badgeColor      String?  // Hex or Tailwind token, e.g. "#2d2d2d"
  priority        Int      @default(0)
  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  createdBy User                @relation("RoleCreator", fields: [createdByUserId], references: [id])
  scope     OfficialRoleScope[]
  userRoles UserOfficialRole[]
}

// Polymorphic scope binding: one role can cover multiple admin units or zones.
// adminUnitName is set for FEDERAL_STATE | COUNTY | MUNICIPALITY (matches Finding.adminXxx fields).
// zoneId is set for ZONE — the official has authority over findings within that zone's geometry.
model OfficialRoleScope {
  id             String        @id @default(uuid())
  officialRoleId String
  adminUnitType  AdminUnitType
  adminUnitName  String?       // e.g. "Bayern", "München (Landkreis)"
  zoneId         String?       // references a user-created Zone

  officialRole OfficialRole @relation(fields: [officialRoleId], references: [id], onDelete: Cascade)
  zone         Zone?        @relation(fields: [zoneId], references: [id])
}

// Many-to-many: user ↔ role assignment with full audit trail.
model UserOfficialRole {
  id               String    @id @default(uuid())
  userId           String
  officialRoleId   String
  assignedByUserId String
  assignedAt       DateTime  @default(now())
  expiresAt        DateTime? // Optional expiry for time-limited assignments

  user         User         @relation("UserRoles", fields: [userId], references: [id], onDelete: Cascade)
  officialRole OfficialRole @relation(fields: [officialRoleId], references: [id], onDelete: Cascade)
  assignedBy   User         @relation("RoleAssigner", fields: [assignedByUserId], references: [id])

  @@unique([userId, officialRoleId])
}

// Sensitive PII — stored separately from User for access-control isolation.
// Fields are encrypted at the application layer via prisma-field-encryption.
// Access is restricted in API routes to users holding the VIEW_USER_DATA capability.
model UserProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  firstName String   /// @encrypted
  lastName  String   /// @encrypted
  street    String?  /// @encrypted
  city      String?  /// @encrypted
  zipcode   String?  /// @encrypted
  birthdate String?  /// @encrypted — stored as ISO date string "YYYY-MM-DD", encrypted before write
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum NotificationType {
  MENTION
  REPLY
  FINDING_COMMENT
}

enum FindingStatus {
  DRAFT
  COMPLETED
}
